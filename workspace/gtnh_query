#!/usr/bin/env sh
set -eu

BASE="$(cd "$(dirname "$0")" && pwd)"
ITEMS="${GTNH_ITEMS_INDEX:-$BASE/gtnh-data/index/item_index.tsv}"
RECIPES="${GTNH_RECIPES_INDEX:-$BASE/gtnh-data/index/recipe_index.tsv}"

fail() {
  printf '{"ok":false,"error":"%s"}\n' "$1"
  exit 1
}

[ -f "$ITEMS" ] || fail "missing index: $ITEMS"
[ -f "$RECIPES" ] || fail "missing index: $RECIPES"

cmd="${1:-}"
shift || true

json_escape() {
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

find_item() {
  q="${1:-}"
  [ -n "$q" ] || fail "usage: find-item <text>"
  ql="$(printf '%s' "$q" | tr '[:upper:]' '[:lower:]')"

  awk -F '\t' -v q="$ql" '
    function norm(s, t) {
      t = tolower(s)
      gsub(/[^a-z0-9]+/, " ", t)
      gsub(/^ +| +$/, "", t)
      gsub(/ +/, " ", t)
      return t
    }
    function add_candidate(score, slug, display, reg, name, i, worst, idx) {
      if (seen[slug]) return

      if (count < 20) {
        count++
        idx = count
      } else {
        worst = 1
        for (i = 2; i <= count; i++) {
          if (scores[i] > scores[worst] || (scores[i] == scores[worst] && tolower(displays[i]) > tolower(displays[worst]))) {
            worst = i
          }
        }
        if (score > scores[worst] || (score == scores[worst] && tolower(display) >= tolower(displays[worst]))) {
          return
        }
        delete seen[slugs[worst]]
        idx = worst
      }

      seen[slug] = 1
      scores[idx] = score
      slugs[idx] = slug
      displays[idx] = display
      regs[idx] = reg
      names[idx] = name
    }
    BEGIN {
      qn = norm(q)
      qtok_n = split(qn, qtok, " ")
      count = 0
    }
    NR == 1 { next }
    {
      d = norm($2)
      r = norm($3)
      n = norm($4)
      all = d " " r " " n
      score = 999999

      if (d == qn || r == qn || n == qn) {
        score = 0
      } else if (index(d, qn) > 0 || index(r, qn) > 0 || index(n, qn) > 0) {
        score = 50 + length(d)
      } else {
        hits = 0
        for (i = 1; i <= qtok_n; i++) {
          tok = qtok[i]
          if (length(tok) < 3) { continue }
          if (index(all, tok) > 0) {
            hits++
          }
        }
        if (hits > 0) {
          score = 200 - (hits * 30) + length(d)
        }
      }

      if (score < 999999) {
        add_candidate(score, $1, $2, $3, $4)
      }
    }
    END {
      for (i = 1; i <= count; i++) ord[i] = i
      for (i = 1; i <= count; i++) {
        for (j = i + 1; j <= count; j++) {
          a = ord[i]
          b = ord[j]
          if (scores[b] < scores[a] || (scores[b] == scores[a] && tolower(displays[b]) < tolower(displays[a]))) {
            t = ord[i]
            ord[i] = ord[j]
            ord[j] = t
          }
        }
      }

      out = 0
      for (i = 1; i <= count; i++) {
        idx = ord[i]
        if (out > 0) { printf(",") }
        printf("{\"slug\":\"%s\",\"display_name\":\"%s\",\"reg_name\":\"%s\",\"name\":\"%s\"}", slugs[idx], displays[idx], regs[idx], names[idx])
        out++
        if (out >= 20) break
      }
      printf("\n")
    }
  ' "$ITEMS" | awk -v query="$(json_escape "$q")" '
    BEGIN { printf("{\"ok\":true,\"query\":\"%s\",\"items\":[", query) }
    { printf("%s", $0) }
    END { printf("]}\n") }
  '
}
resolve_recipes() {
  q="${1:-}"
  [ -n "$q" ] || fail "usage: resolve-recipes <text>"
  ql="$(printf '%s' "$q" | tr '[:upper:]' '[:lower:]')"

  slug="$(awk -F '\t' -v q="$ql" '
    function norm(s, t) {
      t = tolower(s)
      gsub(/[^a-z0-9]+/, " ", t)
      gsub(/^ +| +$/, "", t)
      gsub(/ +/, " ", t)
      return t
    }
    function is_subseq(needle, hay, i, j, ch) {
      i = 1
      for (j = 1; j <= length(hay); j++) {
        ch = substr(hay, j, 1)
        if (ch == substr(needle, i, 1)) {
          i++
          if (i > length(needle)) { return 1 }
        }
      }
      return 0
    }
    BEGIN {
      best = 999999
      qn = norm(q)
      qtok_n = split(qn, qtok, " ")
    }
    NR == 1 { next }
    {
      d = norm($2)
      r = norm($3)
      n = norm($4)
      all = d " " r " " n
      score = 999999
      if (d == qn || r == qn || n == qn) {
        score = 0
      } else if (d == qn " ingot" || n == qn " ingot") {
        score = 1
      } else if (index(d, qn) > 0 || index(r, qn) > 0 || index(n, qn) > 0) {
        score = 50 + length(d)
      } else if (is_subseq(qn, d)) {
        score = 120 + length(d)
      } else {
        hits = 0
        near_hits = 0
        for (i = 1; i <= qtok_n; i++) {
          tok = qtok[i]
          if (length(tok) < 3) { continue }
          if (index(all, tok) > 0) {
            hits++
          } else if (is_subseq(tok, all)) {
            near_hits++
          }
        }
        if (hits > 0 || near_hits > 0) {
          score = 500 - (hits * 40) - (near_hits * 20) + length(d)
        }
      }
      if (score < best) {
        best = score
        slug = $1
      }
    }
    END {
      if (best < 999999) {
        print slug
      }
    }
  ' "$ITEMS")"

  [ -n "$slug" ] || fail "item not found"

  awk -F '\t' -v s="$slug" '
    BEGIN { out = 0 }
    NR == 1 { next }
    ($1 == s || $3 == s) {
      if (out > 0) { printf(",") }
      printf("{\"query_slug\":\"%s\",\"query_name\":\"%s\",\"out_slug\":\"%s\",\"out_name\":\"%s\",\"handler\":\"%s\",\"tab\":\"%s\",\"ingredients\":\"%s\"}", $1, $2, $3, $4, $5, $6, $7)
      out++
      if (out >= 30) { exit }
    }
    END { printf("\n") }
  ' "$RECIPES" | awk -v query="$(json_escape "$q")" -v slug="$(json_escape "$slug")" '
    BEGIN { printf("{\"ok\":true,\"query\":\"%s\",\"slug\":\"%s\",\"recipes\":[", query, slug) }
    { printf("%s", $0) }
    END { printf("],\"sources\":[\"gtnh-data/index/item_index.tsv\",\"gtnh-data/index/recipe_index.tsv\"]}\n") }
  '
}

search_recipes() {
  q="${1:-}"
  [ -n "$q" ] || fail "usage: search-recipes <text>"
  ql="$(printf '%s' "$q" | tr '[:upper:]' '[:lower:]')"

  cand="$(mktemp)"
  rec="$(mktemp)"
  trap 'rm -f "$cand" "$rec"' EXIT

  awk -F '\t' -v q="$ql" '
    function norm(s, t) {
      t = tolower(s)
      gsub(/[^a-z0-9]+/, " ", t)
      gsub(/^ +| +$/, "", t)
      gsub(/ +/, " ", t)
      return t
    }
    function is_subseq(needle, hay, i, j, ch) {
      i = 1
      for (j = 1; j <= length(hay); j++) {
        ch = substr(hay, j, 1)
        if (ch == substr(needle, i, 1)) {
          i++
          if (i > length(needle)) { return 1 }
        }
      }
      return 0
    }
    BEGIN {
      qn = norm(q)
      qtok_n = split(qn, qtok, " ")
    }
    NR == 1 { next }
    {
      d = norm($2)
      r = norm($3)
      n = norm($4)
      all = d " " r " " n
      score = 999999
      if (d == qn || r == qn || n == qn) {
        score = 0
      } else if (d == qn " ingot" || n == qn " ingot") {
        score = 1
      } else if (index(d, qn) > 0 || index(r, qn) > 0 || index(n, qn) > 0) {
        score = 50 + length(d)
      } else if (is_subseq(qn, d)) {
        score = 120 + length(d)
      } else {
        hits = 0
        near_hits = 0
        for (i = 1; i <= qtok_n; i++) {
          tok = qtok[i]
          if (length(tok) < 3) { continue }
          if (index(all, tok) > 0) {
            hits++
          } else if (is_subseq(tok, all)) {
            near_hits++
          }
        }
        if (hits > 0 || near_hits > 0) {
          score = 500 - (hits * 40) - (near_hits * 20) + length(d)
        }
      }
      if (score < 999999) {
        printf("%d\t%s\t%s\n", score, $1, $2)
      }
    }
  ' "$ITEMS" | sort -t "$(printf '\t')" -k1,1n -k3,3 | awk -F '\t' '
    !seen[$2]++ {
      print $2 "\t" $3
      c++
      if (c >= 20) {
        exit
      }
    }
  ' > "$cand"

  if [ ! -s "$cand" ]; then
    fail "item not found"
  fi

  awk -F '\t' '
    NR == FNR {
      cand[$1] = $2
      next
    }
    FNR == 1 { next }
    {
      hit1 = ($1 in cand)
      hit3 = ($3 in cand)
      if (!(hit1 || hit3)) {
        next
      }
      slug = $1
      if (!hit1) {
        slug = $3
      }
      printf("%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n", slug, cand[slug], $1, $2, $3, $4, $5, $6, $7)
    }
  ' "$cand" "$RECIPES" > "$rec"

  printf '{"ok":true,"query":"%s","matched_items":[' "$(json_escape "$q")"
  first=1
  while IFS="$(printf '\t')" read -r slug dname; do
    [ -n "$slug" ] || continue
    if [ "$first" -eq 0 ]; then
      printf ','
    fi
    first=0
    printf '{"slug":"%s","display_name":"%s"}' "$(json_escape "$slug")" "$(json_escape "$dname")"
  done < "$cand"

  printf '],"recipes":['
  first=1
  recipe_count=0
  while IFS="$(printf '\t')" read -r mslug mname qslug qname oslug oname handler tab ingredients; do
    [ -n "$mslug" ] || continue
    if [ "$recipe_count" -ge 80 ]; then
      break
    fi
    if [ "$first" -eq 0 ]; then
      printf ','
    fi
    first=0
    printf '{"match_slug":"%s","match_name":"%s","query_slug":"%s","query_name":"%s","out_slug":"%s","out_name":"%s","handler":"%s","tab":"%s","ingredients":"%s"}' \
      "$(json_escape "$mslug")" "$(json_escape "$mname")" "$(json_escape "$qslug")" "$(json_escape "$qname")" \
      "$(json_escape "$oslug")" "$(json_escape "$oname")" "$(json_escape "$handler")" "$(json_escape "$tab")" \
      "$(json_escape "$ingredients")"
    recipe_count=$((recipe_count + 1))
  done < "$rec"

  printf '],"sources":["gtnh-data/index/item_index.tsv","gtnh-data/index/recipe_index.tsv"]}\n'
}

item() {
  slug="${1:-}"
  [ -n "$slug" ] || fail "usage: item <slug>"
  awk -F '\t' -v s="$slug" '
    NR == 1 { next }
    $1 == s {
      printf("{\"ok\":true,\"item\":{\"slug\":\"%s\",\"display_name\":\"%s\",\"reg_name\":\"%s\",\"name\":\"%s\"},\"source\":\"gtnh-data/index/item_index.tsv\"}\n", $1, $2, $3, $4)
      found = 1
      exit
    }
    END {
      if (!found) {
        printf("{\"ok\":false,\"error\":\"item not found\",\"slug\":\"%s\"}\n", s)
      }
    }
  ' "$ITEMS"
}

case "$cmd" in
  find-item)
    find_item "${1:-}"
    ;;
  resolve-recipes)
    resolve_recipes "${1:-}"
    ;;
  search-recipes)
    search_recipes "${1:-}"
    ;;
  item)
    item "${1:-}"
    ;;
  *)
    fail "unknown command: $cmd (use: find-item, resolve-recipes, search-recipes, item)"
    ;;
esac
