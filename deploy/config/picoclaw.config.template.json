{
  "agents": {
    "defaults": {
      "workspace": "~/.picoclaw/workspace",
      "restrict_to_workspace": true,
      "provider": "openai",
      "model": "gpt-5.1-codex-mini",
      "model_name": "gpt-5.1-codex-mini",
      "max_tokens": 8192,
      "temperature": 0.2,
      "max_tool_iterations": 128
    }
  },
  "model_list": [
    {
      "model_name": "gpt-5.1-codex-mini",
      "model": "openai/gpt-5.1-codex-mini",
      "auth_method": "oauth"
    }
  ],
  "providers": {
    "openai": {
      "auth_method": "oauth",
      "api_key": "",
      "api_base": "https://api.openai.com/v1"
    }
  },
  "channels": {
    "discord": {
      "enabled": true,
      "token": "REPLACE_WITH_DISCORD_BOT_TOKEN",
      "allow_from": [
        "REPLACE_WITH_DISCORD_USER_ID"
      ],
      "mention_only": true,
      "reasoning_channel_id": ""
    }
  },
  "tools": {
    "web": {
      "duckduckgo": {
        "enabled": true,
        "max_results": 5
      }
    },
    "exec": {
      "enable_deny_patterns": true,
      "custom_deny_patterns": [
        "(^|\\s)cd\\s",
        "&&|\\|\\||;|\\|",
        "[\\x00-\\x1F]"
      ]
    }
  },
  "gateway": {
    "host": "0.0.0.0",
    "port": 18790
  },
  "heartbeat": {
    "enabled": true,
    "interval": 30
  },
  "devices": {
    "enabled": false,
    "monitor_usb": false
  }
}
